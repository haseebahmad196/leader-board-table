generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Player {
  id        String        @id @default(cuid())
  name      String        @unique
  createdAt DateTime      @default(now())
  matchRows MatchPlayer[]
}

model Match {
  id         String        @id @default(cuid())
  playedAt   DateTime
  rawMessage String?
  scoreTeamA Int
  scoreTeamB Int
  createdAt  DateTime      @default(now())
  players    MatchPlayer[]
}

model MatchPlayer {
  id       String @id @default(cuid())
  matchId  String
  playerId String
  team     String

  match  Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
}